    <string name="tutorial_p1_title">Welcome to QRShield</string>
    <string name="tutorial_p1_body">Your personal QR code security scanner. Every code you scan is analyzed for threats before you interact with it.</string>

    <string name="tutorial_p2_title">Instant Camera Scanning</string>
    <string name="tutorial_p2_body">Just point your camera at any QR code. QRShield detects and analyzes it automatically in real time — no button press needed.</string>

    <string name="tutorial_p3_title">Scan from Gallery</string>
    <string name="tutorial_p3_body">Have a QR code in a screenshot or photo? Tap the image icon in the top bar to pick it straight from your gallery.</string>

    <string name="tutorial_p4_title">Understanding Results</string>
    <string name="tutorial_p4_body">Each scan gets a verdict — Safe, Suspicious, or Dangerous — backed by VirusTotal\'s database of 90+ security vendors.</string>

    <string name="tutorial_p5_title">Your Scan History</string>
    <string name="tutorial_p5_body">All scans are saved automatically. Tap the history icon any time to review past results and re-open previous verdicts.</string>
